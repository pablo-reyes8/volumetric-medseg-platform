UNET3D_ENV=local
UNET3D_MODEL_CONFIG=model.yaml
UNET3D_MODEL_PATH=artifacts/models/champion/model.pt
UNET3D_CHECKPOINT_PATH=artifacts/models/champion/model.pt
UNET3D_ARTIFACT_ROOT=artifacts
UNET3D_DATA_ROOT=data
UNET3D_MLFLOW_TRACKING_URI=http://localhost:5000
UNET3D_LOG_LEVEL=INFO
UNET3D_ENABLE_RUNTIME_MONITORING=true
UNET3D_PROMETHEUS_ENABLED=true
UNET3D_PREDICTION_LOG_PATH=artifacts/predictions/prediction_log.jsonl
UNET3D_REVIEW_FEEDBACK_PATH=artifacts/feedback/review_feedback.jsonl
UNET3D_PRELOAD_MODEL=false
